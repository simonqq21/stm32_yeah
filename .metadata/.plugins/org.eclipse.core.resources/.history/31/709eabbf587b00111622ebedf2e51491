#define GPIO_CRH_MODE_1(n) ((n-8)*4+1)	// GPIO 13 = 21 ;(13-8) * 4 + 1
#define GPIO_CRH_MODE_0(n) // GPIO 13 = 20 ;(13-8) * 4 + 0
#define GPIO_CRH_CNF_1(n) // GPIO 13 = 23 ;(13-8) * 4 + 3
#define GPIO_CRH_CNF_0(n) // GPIO 13 = 22 ;(13-8) * 4 + 2
#define GPIOCEN 			(1U<<4)
#define PIN13				(1U<<13)
#define LED_PIN				(PIN13)

int main(void)
{
	/* 1. enable clock access to GPIOC */
	RCC->APB2ENR |= GPIOCEN;
	/*	2. Set PC13 as output pin
	 * set PC13 CNF to 00 to set to output push-pull
	 * set PC13 MODE to 01 to set max speed to 10 MHz*/
	GPIOC->CRH &= 0;

    while (1) {
    	GPIOC->ODR ^= LED_PIN;
    	for (int i=0;i<50000;i++);
    }
}
