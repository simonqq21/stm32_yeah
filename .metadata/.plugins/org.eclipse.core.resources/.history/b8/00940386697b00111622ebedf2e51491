#define LED_PIN				(GPIO_ODR_ODR13)

int main(void)
{
	/* 1. enable clock access to GPIOC */
	RCC->APB2ENR |= RCC_APB2ENR_IOPCEN;
	/*	2. Set PC13 as output pin
	 * set PC13 CNF to 00 to set to output push-pull
	 * set PC13 MODE to 01 to set max speed to 10 MHz*/
	GPIOC->CRH &= ~GPIO_CRH_MODE13_1;
	GPIOC->CRH |= GPIO_CRH_MODE13_0;
	GPIOC->CRH &= ~GPIO_CRH_CNF13_1;
	GPIOC->CRH &= ~GPIO_CRH_CNF13_0;
	/* Set PA5 as pulled up input  pin
	 * set CNF to 10
	 * set MODE to 00
	 * set ODR to 1
	 * */
	GPIOA->CRL |= GPIO_CRL_CNF5_1;
	GPIOA->CRL &= ~GPIO_CRL_CNF5_0;
	GPIOA->CRL &= ~GPIO_CRL_MODE5_1;
	GPIOA->CRL &= ~GPIO_CRL_MODE5_0;
	GPIOA->ODR |= GPIO_ODR_ODR5;

    while (1) {
//    	if button is pressed, switch LED on
    	if (GPIOA->IDR & GPIO_IDR_IDR5) {
    		GPIOC->BSRR |= GPIO_BSRR_BS13;
    	} else {
    		GPIOC->BSRR |= GPIO_BSRR_BR13;
    	}
//    	else switch LED off.




    }
}
